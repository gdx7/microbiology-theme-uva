# Environment variables for the Payload CMS integration.
# Copy to .env.local for local dev, and set the same keys in the Vercel
# project settings (all environments) for production.

# Required. A long random string used to sign Payload auth tokens.
#   generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=

# Production database (Neon serverless Postgres or Vercel Postgres).
# Leave UNSET locally — with no DATABASE_URI, Payload uses a local SQLite file
# (payload-dev.db) so you can run /admin without provisioning anything.
# DATABASE_URI=postgres://user:password@host/db?sslmode=require

# Production media storage (Vercel Blob). Leave UNSET locally — uploads then
# go to public/media on disk. In production this is REQUIRED (Vercel's
# filesystem is ephemeral, so local uploads would be lost).
# BLOB_READ_WRITE_TOKEN=

# Optional. Overrides for the first admin account created by the seed
# (defaults: admin@microbiology-sils.nl / ChangeMe123!).
# SEED_ADMIN_EMAIL=
# SEED_ADMIN_PASSWORD=

# Set to "true" ONLY for the one-time production seed via /api/seed, then remove.
# ALLOW_SEED=true

# --- Legacy (Decap CMS — being retired, safe to remove once Payload is live) ---
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=
